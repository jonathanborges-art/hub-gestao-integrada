# Copie para .env (uso local) ou configure como variáveis de ambiente no Render.

# Connection string do Postgres do Supabase.
# Pegue em: Supabase Dashboard -> Project Settings -> Database -> Connection string (URI)
# Recomendado usar o modo "Transaction pooler" (porta 6543) em produção.
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.SEU_PROJETO.supabase.co:5432/postgres

# Chave secreta usada para assinar os tokens de login (JWT).
# Gere uma string aleatória longa e única — nunca reaproveite a de outro projeto.
JWT_SECRET=troque-para-uma-string-aleatoria-bem-longa

# Porta do servidor (o Render define isso automaticamente, não precisa mexer)
PORT=3333
